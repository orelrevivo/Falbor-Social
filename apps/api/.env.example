# API Server Environment Variables
# Copy this file to .env and fill in the values

# Neon PostgreSQL connection string
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/hey?sslmode=require

# JWT Secrets — use long random strings (e.g., openssl rand -hex 64)
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret_key

# Token expiry durations
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server port
PORT=3000

# CORS origin (the URL of your frontend)
CORS_ORIGIN=http://localhost:4783
